FROM golang:1.22-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /muselet-sidecar ./cmd/sidecar

FROM alpine:3.19
RUN mkdir -p /var/run/muselet /var/log/muselet /etc/muselet
COPY --from=builder /muselet-sidecar /usr/local/bin/muselet-sidecar
COPY policies/default.yaml /etc/muselet/policy.yaml
EXPOSE 8080
ENTRYPOINT ["muselet-sidecar"]
